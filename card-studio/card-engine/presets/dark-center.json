{
  "id": "dark-center",
  "name": "Dark Center",
  "description": "다크 배경, 중앙 초대형 기록, 사진 배경",
  "version": "1.2.0",

  "card": {
    "background": "#0A0A0A",
    "css": ""
  },

  "layers": [
    {
      "id": "photo",
      "type": "component",
      "componentId": "photo",
      "label": "배경 사진",
      "componentStyle": {
        "filter": "grayscale(100%) contrast(1.15) brightness(0.45)"
      }
    },
    {
      "id": "overlay",
      "type": "absolute",
      "position": { "slot": "full" },
      "style": { "background": "rgba(0,0,0,0.55)", "zIndex": 1 }
    },

    {
      "id": "brand-area",
      "type": "absolute",
      "label": "AthleTime 로고",
      "position": { "top": 48, "left": 72, "zIndex": 5 },
      "children": [
        {
          "id": "brand",
          "type": "component",
          "componentId": "brand",
          "label": "브랜드 로고",
          "componentStyle": {
            "color": "rgba(255,255,255,0.5)",
            "borderColor": "rgba(255,255,255,0.5)",
            "strokeColor": "rgba(255,255,255,0.5)",
            "logoSize": 34,
            "text": { "fontSize": 16, "letterSpacing": 5, "color": "rgba(255,255,255,0.5)" }
          }
        }
      ]
    },

    {
      "id": "rank-area",
      "type": "absolute",
      "position": { "top": 48, "right": 72, "zIndex": 5 },
      "children": [
        {
          "id": "rank",
          "type": "component",
          "componentId": "rank",
          "label": "순위",
          "componentStyle": {
            "layout": "inline",
            "label": { "fontSize": 13, "fontWeight": 800, "color": "rgba(255,255,255,0.3)", "letterSpacing": 4 },
            "value": { "fontSize": 84, "fontWeight": 900, "color": "#FFFFFF", "lineHeight": 1 },
            "container": { "flexDirection": "column", "alignItems": "center", "gap": 4 }
          }
        }
      ]
    },

    {
      "id": "center-record",
      "type": "absolute",
      "position": { "slot": "center", "zIndex": 3 },
      "style": { "textAlign": "center", "width": "85%" },
      "children": [
        {
          "id": "record",
          "type": "component",
          "componentId": "record",
          "label": "기록",
          "componentStyle": { "fontSize": 176, "fontWeight": 900, "color": "#FFFFFF", "letterSpacing": -8, "lineHeight": 0.92, "textAlign": "center", "textShadow": "0 6px 80px rgba(0,0,0,0.6)", "unit": { "fontSize": 32, "fontWeight": 700, "color": "rgba(255,255,255,0.35)", "display": "block", "marginTop": 12 } }
        },
        {
          "id": "wind",
          "type": "component",
          "componentId": "wind",
          "label": "풍속",
          "componentStyle": { "fontSize": 16, "fontWeight": 500, "color": "rgba(255,255,255,0.3)", "letterSpacing": 2.5, "marginTop": 20, "textAlign": "center" }
        }
      ]
    },

    {
      "id": "bottom-content",
      "type": "absolute",
      "position": { "slot": "bottom-left", "right": 0, "padding": [0, 72, 72, 72], "zIndex": 3 },
      "children": [
        {
          "id": "event",
          "type": "component",
          "componentId": "event",
          "label": "종목",
          "componentStyle": { "fontSize": 20, "fontWeight": 800, "color": "rgba(255,255,255,0.45)", "letterSpacing": 3, "textTransform": "uppercase", "marginBottom": 16 }
        },
        {
          "id": "bottom-divider",
          "type": "component",
          "componentId": "divider",
          "label": "구분선",
          "componentStyle": { "height": 2, "background": "rgba(255,255,255,0.15)", "marginBottom": 24 }
        },
        {
          "id": "info-row",
          "type": "row",
          "style": { "justify": "space-between", "align": "flex-end" },
          "children": [
            {
              "id": "athlete-info",
              "type": "group",
              "style": { "gap": 0, "flex": 1, "minWidth": 0 },
              "children": [
                {
                  "id": "athleteName",
                  "type": "component",
                  "componentId": "athleteName",
                  "label": "선수명",
                  "componentStyle": { "fontSize": 56, "fontWeight": 900, "color": "#FFFFFF", "letterSpacing": -1.5, "lineHeight": 1.1 }
                },
                {
                  "id": "affiliation",
                  "type": "component",
                  "componentId": "affiliation",
                  "label": "소속",
                  "componentStyle": { "fontSize": 22, "fontWeight": 500, "color": "rgba(255,255,255,0.4)", "marginTop": 12 }
                }
              ]
            },
            {
              "id": "comp-info",
              "type": "group",
              "style": { "textAlign": "right", "gap": 5, "alignItems": "flex-end", "flexShrink": 0, "marginLeft": 28 },
              "children": [
                {
                  "id": "competition",
                  "type": "component",
                  "componentId": "competition",
                  "label": "대회명",
                  "componentStyle": { "fontSize": 15, "fontWeight": 600, "color": "rgba(255,255,255,0.35)", "textAlign": "right" }
                },
                {
                  "id": "date",
                  "type": "component",
                  "componentId": "date",
                  "label": "날짜·장소",
                  "componentStyle": { "fontSize": 14, "fontWeight": 400, "color": "rgba(255,255,255,0.2)", "textAlign": "right" }
                }
              ]
            }
          ]
        },
        {
          "id": "comment",
          "type": "component",
          "componentId": "comment",
          "label": "코멘트",
          "componentStyle": { "fontSize": 19, "fontWeight": 500, "color": "rgba(255,255,255,0.4)", "fontStyle": "italic", "textAlign": "center", "marginTop": 26, "paddingTop": 22, "borderTop": "1px solid rgba(255,255,255,0.08)", "lineHeight": 1.5 }
        }
      ]
    }
  ]
}