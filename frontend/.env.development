# Athlete Time - 개발 환경 변수

# 백엔드 API URL
# 빈 값 = 상대 경로(/api/...)를 사용 → vite.config.ts의 proxy가
# 로컬 백엔드(http://localhost:3005)로 전달한다. (dev 기본값)
# Render 원격 백엔드로 붙어서 테스트하려면 .env.development.remote 사용:
#   npm run dev -- --mode development.remote
VITE_API_BASE_URL=

# 프론트엔드 URL (로컬)
VITE_FRONTEND_URL=http://localhost:5173

# 애플리케이션 설정
VITE_APP_NAME=Athlete Time (Dev)
VITE_APP_VERSION=3.0.0-dev

# API 타임아웃 (밀리초)
VITE_API_TIMEOUT=30000

# 디버그 모드 (개발에서는 true)
VITE_DEBUG=true
