# Athlete Time - 개발(원격 백엔드) 환경 변수
#
# Render에 배포된 원격 백엔드로 직접 붙어서 테스트할 때만 사용한다.
# 실행: npm run dev -- --mode development.remote
#
# 주의: 이 모드에서는 Vite proxy를 거치지 않고 절대 URL로 호출하므로
# 원격 백엔드에 해당 API가 배포돼 있어야 한다. (없으면 404 → 홈 D-day 보드 폴백)

VITE_API_BASE_URL=https://athletetime-backend.onrender.com
VITE_FRONTEND_URL=http://localhost:5173
VITE_APP_NAME=Athlete Time (Dev · Remote)
VITE_APP_VERSION=3.0.0-dev
VITE_API_TIMEOUT=30000
VITE_DEBUG=true
